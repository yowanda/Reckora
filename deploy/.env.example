# Reckora — runtime configuration template.
#
# Copy this to ``.env`` next to ``docker-compose.yml`` and fill in the
# blanks. Every ``RECKORA_API_*`` variable is consumed by ``apps/api``;
# every ``RECKORA_*`` variable is consumed by the underlying engine.

# ───────────────────────────────────────────────────────────────────────
# Required
# ───────────────────────────────────────────────────────────────────────

# Public hostname Caddy should issue a TLS cert for. Must already point
# at this host's public IP via an A record before ``docker compose up``.
DOMAIN=reckora.example.com

# JWT signing key for ``apps/api``. Must be high-entropy. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
RECKORA_API_JWT_SECRET=

# CORS origins — for the same-origin Caddy deploy this can stay set to
# the public domain. Set to ``"*"`` only for development.
RECKORA_API_CORS_ORIGINS=https://reckora.example.com

# ───────────────────────────────────────────────────────────────────────
# Optional — third-party API keys
# ───────────────────────────────────────────────────────────────────────

# OpenAI API key (Reasoning + summaries). Leave blank to fall back to
# the ChatGPT OAuth flow the operator can run via `reckora auth login`.
OPENAI_API_KEY=

# HaveIBeenPwned API key (only used when --breach is passed on the CLI
# or when the API operator opts in per-investigation).
HIBP_API_KEY=

# Etherscan API key (raises ETH wallet rate limit from 1 rps -> 5 rps).
ETHERSCAN_API_KEY=

# Optional GitHub token (raises GitHub collector rate limits and unlocks
# private-org-membership checks).
GITHUB_TOKEN=

# AgentRouter system fallback key. Users can also save their own BYOK
# key from the app; this env var is used when no per-user key exists.
# AGENTROUTER_API_KEY=
#
# AgentRouter endpoint/model overrides. Leave commented unless the
# gateway base URL or default upstream model changes.
# RECKORA_AGENTROUTER_BASE_URL=https://agentrouter.org/
# RECKORA_AGENTROUTER_MODEL=claude-opus-4-6

# Optional model/runtime tuning for the underlying engine.
# RECKORA_OPENAI_MODEL=gpt-4o-mini
# RECKORA_OPENAI_OAUTH_MODEL=gpt-5.5
# RECKORA_USER_AGENT=Reckora/0.1

# ───────────────────────────────────────────────────────────────────────
# Optional — API runtime settings
# ───────────────────────────────────────────────────────────────────────

# JWT signing algorithm. Keep HS256 unless all deployed services agree
# on a different algorithm.
# RECKORA_API_JWT_ALGORITHM=HS256

# Lifetime of issued bearer tokens, in seconds.
RECKORA_API_JWT_TTL_SECONDS=3600

# Whether ``/docs`` and ``/redoc`` are exposed on the public domain.
# Set to ``false`` for production deployments that already publish a
# spec elsewhere.
RECKORA_API_DOCS_ENABLED=true

# Storage paths. The Docker compose file already sets these to the
# mounted /data volume for the api service; uncomment only for non-compose
# runs or custom layouts.
# RECKORA_DB_PATH=/data/reckora.db
# RECKORA_API_SCREENSHOTS_DIR=/data/screenshots
# RECKORA_API_SCREENSHOTS_URL_PREFIX=/screenshots

# Fernet key path for encrypting saved per-user secrets, such as BYOK
# AgentRouter API keys. If unset, Reckora stores the generated key next
# to the SQLite database as ``${RECKORA_DB_PATH}.fernet``.
# RECKORA_API_FERNET_KEY_PATH=/data/reckora.db.fernet
