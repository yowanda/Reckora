# Reckora — runtime configuration template.
#
# Copy this to ``.env`` next to ``docker-compose.yml`` and fill in the
# blanks. Every ``RECKORA_API_*`` variable is consumed by ``apps/api``;
# every ``RECKORA_*`` variable is consumed by the underlying engine.

# ───────────────────────────────────────────────────────────────────────
# Required
# ───────────────────────────────────────────────────────────────────────

# Public hostname Caddy should issue a TLS cert for. Must already point
# at this host's public IP via an A record before ``docker compose up``.
DOMAIN=reckora.example.com

# JWT signing key for ``apps/api``. Must be high-entropy. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
RECKORA_API_JWT_SECRET=

# CORS origins — for the same-origin Caddy deploy this can stay set to
# the public domain. Set to ``"*"`` only for development.
RECKORA_API_CORS_ORIGINS=https://reckora.example.com

# ───────────────────────────────────────────────────────────────────────
# Optional — third-party API keys
# ───────────────────────────────────────────────────────────────────────

# OpenAI API key (Reasoning + summaries). Leave blank to fall back to
# the ChatGPT OAuth flow the operator can run via `reckora auth login`.
OPENAI_API_KEY=

# HaveIBeenPwned API key (only used when --breach is passed on the CLI
# or when the API operator opts in per-investigation).
HIBP_API_KEY=

# Etherscan API key (raises ETH wallet rate limit from 1 rps -> 5 rps).
ETHERSCAN_API_KEY=

# Optional GitHub token (raises GitHub collector rate limits and unlocks
# private-org-membership checks).
GITHUB_TOKEN=

# ───────────────────────────────────────────────────────────────────────
# Optional — JWT lifetime / docs visibility
# ───────────────────────────────────────────────────────────────────────

# Lifetime of issued bearer tokens, in seconds.
RECKORA_API_JWT_TTL_SECONDS=3600

# Whether ``/docs`` and ``/redoc`` are exposed on the public domain.
# Set to ``false`` for production deployments that already publish a
# spec elsewhere.
RECKORA_API_DOCS_ENABLED=true
